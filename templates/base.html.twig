<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}TaskFlow
			{% endblock %}
		</title>

		<!-- Favicon - ADD THESE LINES -->
		<link
		rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">
		{# <link rel="alternate icon" href="{{ asset('favicon.ico') }}" type="image/x-icon"> #}

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
		<style>
			.navbar-brand {
				font-weight: bold;
				font-size: 1.5rem;
			}
			.user-email {
				color: rgba(255, 255, 255, 0.8);
				margin-right: 15px;
			}
			.nav-link {
				color: white !important;
				margin: 0 5px;
			}
			.nav-link:hover {
				color: rgba(255, 255, 255, 0.8) !important;
			}
		</style>
	</head>
	<body>
		<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
			<div
				class="container-fluid">
				<!-- Logo on LEFT -->
				<a class="navbar-brand" href="{{ path('app_task_index') }}">
					<i class="bi bi-check2-square"></i>
					TaskFlow
				</a>

				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
					<span class="navbar-toggler-icon"></span>
				</button>

				<!-- Right side: User email and navigation links -->
				<div class="collapse navbar-collapse" id="navbarNav">
					<ul class="navbar-nav ms-auto">
						{% if app.user %}
							<li class="nav-item">
								<span class="nav-link">
									<i class="bi bi-person-circle"></i>
									{{ app.user.email }}
								</span>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_task_index') }}">
									<i class="bi bi-list-task"></i>
									Tasks
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_logout') }}">
									<i class="bi bi-box-arrow-right"></i>
									Logout
								</a>
							</li>
						{% else %}
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_login') }}">
									<i class="bi bi-box-arrow-in-right"></i>
									Login
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_register') }}">
									<i class="bi bi-person-plus"></i>
									Sign Up
								</a>
							</li>
						{% endif %}
					</ul>
				</div>
			</div>
		</nav>

		<main class="container mt-4">
			{% for message in app.flashes('success') %}
				<div class="alert alert-success alert-dismissible fade show">
					<i class="bi bi-check-circle-fill"></i>
					{{ message }}
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			{% endfor %}

			{% for message in app.flashes('error') %}
				<div class="alert alert-danger alert-dismissible fade show">
					<i class="bi bi-exclamation-triangle-fill"></i>
					{{ message }}
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			{% endfor %}

			{% block body %}{% endblock %}
		</main>
	</body>
</html>
