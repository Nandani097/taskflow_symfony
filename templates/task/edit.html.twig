{% extends 'base.html.twig' %}

{% block title %}Edit Task #{{ task.id }}
{% endblock %}

{% block body %}
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-md-8">
				<div class="card shadow-sm">
					<div class="card-header bg-warning text-white">
						<h4 class="mb-0">
							<i class="bi bi-pencil-square"></i>
							Edit Task: {{ task.title }}
						</h4>
					</div>
					<div class="card-body">
						{{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}

						<div class="mb-3">
							{{ form_label(form.title, 'Title', {'label_attr': {'class': 'form-label fw-bold'}}) }}
							{{ form_widget(form.title, {'attr': {'class': 'form-control', 'placeholder': 'Enter task title'}}) }}
							<div class="text-danger">{{ form_errors(form.title) }}</div>
						</div>

						<div class="mb-3">
							{{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label fw-bold'}}) }}
							{{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Enter task description'}}) }}
							<div class="text-danger">{{ form_errors(form.description) }}</div>
						</div>

						<div class="row">
							<div class="mb-3">
								{{ form_label(form.status, 'Status', {'label_attr': {'class': 'form-label fw-bold'}}) }}
								{{ form_widget(form.status, {'attr': {'class': 'form-select'}}) }}
								<div class="text-danger">{{ form_errors(form.status) }}</div>
							</div>

							<div class="mb-3">
								{{ form_label(form.priority, 'Priority', {'label_attr': {'class': 'form-label fw-bold'}}) }}
								{{ form_widget(form.priority, {'attr': {'class': 'form-select'}}) }}
								<div class="text-danger">{{ form_errors(form.priority) }}</div>
							</div>
						</div>

						<div class="d-flex justify-content-between mt-4">
							<a href="{{ path('app_task_show', {'id': task.id}) }}" class="btn btn-secondary">
								<i class="bi bi-arrow-left"></i>
								Cancel
							</a>
							<button type="submit" class="btn btn-warning">
								<i class="bi bi-save"></i>
								Update Task
							</button>
						</div>

						{{ form_end(form) }}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
